#include <iostream>
#include <cmath>
using namespace std;

// fungsi yang akan diturunkan
double f(double x)
{
    return pow(x, 3) + 2 * pow(x, 2) - x + 1;
}

int main()
{
    cout << "=== DIFERENSIASI NUMERIK ===" << endl;

    double x, h;
    int pilih;

    cout << "Masukkan nilai x: ";
    cin >> x;

    cout << "Masukkan nilai h (kecil, misal 0.001): ";
    cin >> h;

    cout << "\nPilih metode:\n";
    cout << "1. Selisih Maju\n";
    cout << "2. Selisih Mundur\n";
    cout << "3. Selisih Tengah\n";
    cout << "Pilihan: ";
    cin >> pilih;

    double hasil;

    if (pilih == 1)
    {
        hasil = (f(x + h) - f(x)) / h;
        cout << "\nMetode Selisih Maju\n";
    }
    else if (pilih == 2)
    {
        hasil = (f(x) - f(x - h)) / h;
        cout << "\nMetode Selisih Mundur\n";
    }
    else if (pilih == 3)
    {
        hasil = (f(x + h) - f(x - h)) / (2 * h);
        cout << "\nMetode Selisih Tengah\n";
    }
    else
    {
        cout << "Pilihan tidak valid" << endl;
        return 0;
    }

    cout << "Hasil turunan di x = " << x << " ≈ " << hasil << endl;

    return 0;
}  
